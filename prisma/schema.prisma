generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  purchases Purchase[]
  sales     Sale[]
  settings  Settings?  // Add this line for the relation
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String   @unique
  price       Float
  cost        Float
  quantity    Int      @default(0)
  lowStockThreshold Int @default(5)
  vatCategory  String   @default("VATABLE")  // VATABLE or NON_VATABLE
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]
  
  @@index([sku])
  @@index([name])
}

model Purchase {
  id           String   @id @default(cuid())
  invoiceNo    String   @unique
  supplier     String?
  total        Float
  status       String   @default("ACTIVE")  // ACTIVE, CANCELLED
  cancelReason String?
  cancelledAt  DateTime?
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  items        PurchaseItem[]
  
  @@index([invoiceNo])
  @@index([status])
  @@index([createdAt])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  quantity   Int
  price      Float
  total      Float
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  
  @@unique([purchaseId, productId])
  @@index([purchaseId])
}

model Sale {
  id           String   @id @default(cuid())
  receiptNo    String   @unique
  customer     String?
  subtotal     Float
  tax          Float    @default(0)
  total        Float
  paymentMethod String   @default("CASH")
  status       String   @default("ACTIVE")  // ACTIVE, CANCELLED
  cancelReason String?
  cancelledAt  DateTime?
  createdAt    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  
  items        SaleItem[]
  
  @@index([receiptNo])
  @@index([status])
  @@index([createdAt])
}

model SaleItem {
  id         String   @id @default(cuid())
  quantity   Int
  price      Float
  total      Float
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  saleId     String
  sale       Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  @@unique([saleId, productId])
}

model Settings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  
  // Theme settings
  theme           String   @default("LIGHT")  // LIGHT, DARK
  currency        String   @default("USD")
  currencySymbol  String   @default("$")
  vatPercentage   Int      @default(10)
  
  // Notification settings
  lowStockAlert   Boolean  @default(true)
  autoBackup      Boolean  @default(false)
  
  // Display settings
  dateFormat      String   @default("MM/DD/YYYY")
  language        String   @default("EN")  // EN, FR, ES, etc.
  
  // Receipt settings
  receiptFooter   String   @default("Thank you for your business!")
  
  // Company info
  companyName     String   @default("Stock Management System")
  companyEmail    String   @default("admin@example.com")
  companyPhone    String   @default("+1 234 567 8900")
  companyAddress  String   @default("123 Business St, City, Country")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}